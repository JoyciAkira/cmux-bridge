{
  "expo": {
    "name": "Cmux Bridge",
    "slug": "cmux-bridge",
    "scheme": "cmuxbridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d0d0d",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cmuxbridge.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Cmux Bridge uses Face ID to protect your terminal sessions."
      }
    },
    "android": {
      "package": "com.cmuxbridge.app",
      "adaptiveIcon": {
        "backgroundColor": "#0d0d0d",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Cmux Bridge to use Face ID to unlock your terminal sessions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4ade80",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
